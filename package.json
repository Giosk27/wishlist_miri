{
  "name": "wishlist-site",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
